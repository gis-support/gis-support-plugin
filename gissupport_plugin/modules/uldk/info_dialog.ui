       <item alignment="Qt::AlignTop">
        <widget class="QLabel" name="text_label">
         <property name="text">
          <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;&lt;span style=&quot; font-weight:600;&quot;&gt;Narzędzie posiada 5 trybów pracy:&lt;/span&gt;&lt;/p&gt;&lt;ul style=&quot;margin-top: 0px; margin-bottom: 0px; margin-left: 0px; margin-right: 0px; -qt-list-indent: 1;&quot;&gt;&lt;li style=&quot; margin-top:12px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&lt;span style=&quot; font-weight:600;&quot;&gt;Pojedynczo:&lt;/span&gt; Błyskawiczne wyszukanie i pobranie pojedynczej działki na podstawie jej identyfikatora TERYT.&lt;/li&gt;&lt;li style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&lt;span style=&quot; font-weight:600;&quot;&gt;Z listy:&lt;/span&gt; Załaduj warstwę z projektu, wskaż kolumnę z TERYT i uruchom wyszukiwanie.&lt;/li&gt;&lt;li style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&lt;span style=&quot; font-weight:600;&quot;&gt;Z pliku CSV:&lt;/span&gt; Załaduj plik CSV z dysku, wskaż kolumnę z TERYT i uruchom wyszukiwanie.&lt;/li&gt;&lt;li style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&lt;span style=&quot; font-weight:600;&quot;&gt;Z warstwy:&lt;/span&gt; Wyszukuje działki, które mają wspólną geometrię z warstwą punktową wczytaną do QGIS.&lt;/li&gt;&lt;li style=&quot; margin-top:0px; margin-bottom:12px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&lt;span style=&quot; font-weight:600;&quot;&gt;Sprawdź:&lt;/span&gt; Sprawdza dopasowanie geometrii warstwy źródłowej do obiektów w ULDK.&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;span style=&quot; font-weight:600;&quot;&gt;Elastyczny zapis wyników:&lt;br/&gt;&lt;/span&gt;&lt;br/&gt;Pobrane wyniki wyszukiwania nie muszą tworzyć nowych, oddzielnych plików. Możesz zapisać wygenerowaną geometrię jako nową &lt;span style=&quot; font-weight:600;&quot;&gt;warstwę tymczasową&lt;/span&gt; w pamięci QGIS, bądź automatycznie dodać obiekty do &lt;span style=&quot; font-weight:600;&quot;&gt;istniejącej już warstwy&lt;/span&gt; w Twoim projekcie.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
